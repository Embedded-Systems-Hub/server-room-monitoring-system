{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/Debug/server-room-monitoring-system.elf",
            "device": "STM32F401xE",
            "interface": "swd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "runToEntryPoint": "main",
            "svdFile": "",
            "postLaunchCommands": [
                "set substitute-path /workspace ${workspaceFolder}"
            ],
            "preLaunchTask": "Docker: Compile"
        }
    ]
}
