{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "cmake -B tests/build -S tests && cmake --build tests/build",
            "group": "build",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "cd tests/build && ctest --output-on-failure --output-junit test-results.xml",
            "group": "test",
            "dependsOn": "Build Tests",
            "presentation": { "reveal": "always" }
        }
    ]
}